<!DOCTYPE html>
<html>
<head>
  <title>Common Ground</title>
  <meta name="description" content="Common Ground helps small businesses feel confident online through social media management, brand identity support and content strategy.">

  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,800&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --cream: #f6f2d9;
      --brown: #72492b;
      --orange: #cd6d39;
      --burg: #6b2e2e;
      --blue: #99b6d6;
      --offblack: #373737;
      --yellow: #eab347;
      --olive: #838f40;
      --pink: #efc8c4;
    }

    body {
      margin: 0;
      background-color: var(--cream);
      color: var(--offblack);
      font-family: 'Quicksand', sans-serif;
      line-height: 1.6;
    }

    header {
      padding: 90px 20px 70px;
      text-align: center;
      background-color: var(--cream);
      border-bottom: 3px solid var(--brown);
    }

    h1 {
      font-family: 'Fraunces', serif;
      font-size: 64px;
      margin-bottom: 10px;
      letter-spacing: 1px;
      color: var(--brown);
      text-transform: uppercase;
    }

    h2 {
      font-family: 'Fraunces', serif;
      font-size: 34px;
      margin-bottom: 12px;
      color: var(--brown);
    }

    h3 {
      font-family: 'Fraunces', serif;
      color: var(--brown);
      margin-top: 0;
    }

    p {
      font-size: 18px;
      max-width: 700px;
      margin: 0 auto 20px;
    }

    .intro {
      color: var(--burg);
      font-size: 20px;
      font-weight: bold;
    }

    .button {
      display: inline-block;
      margin: 10px;
      padding: 14px 24px;
      background-color: var(--brown);
      color: var(--cream);
      text-decoration: none;
      border-radius: 30px;
      font-weight: bold;
      border: 2px solid var(--brown);
    }

    .button:hover {
      background-color: var(--burg);
      border-color: var(--burg);
    }

    .button.secondary {
      background-color: var(--orange);
      border-color: var(--orange);
      color: var(--cream);
    }

    .button.secondary:hover {
      background-color: var(--burg);
      border-color: var(--burg);
    }

    .button.green {
      background-color: var(--olive);
      border-color: var(--olive);
      color: var(--cream);
    }

    .button.green:hover {
      background-color: var(--brown);
      border-color: var(--brown);
    }

    .button.small {
      font-size: 15px;
      padding: 10px 18px;
      margin: 10px 0 0;
    }

    section {
      padding: 60px 20px;
      text-align: center;
      background-color: var(--cream);
    }

    .section-line {
      border-top: 2px dashed var(--orange);
      border-bottom: 2px dashed var(--orange);
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      max-width: 900px;
      margin: 30px auto 0;
    }

    .card {
      background-color: var(--cream);
      border: 2px solid var(--brown);
      border-radius: 20px;
      padding: 25px;
      text-align: left;
      box-shadow: 8px 8px 0 var(--pink);
    }

    .card:nth-child(2) {
      box-shadow: 8px 8px 0 var(--blue);
    }

    .card:nth-child(3) {
      box-shadow: 8px 8px 0 var(--yellow);
    }

    .price {
      color: var(--burg);
      font-weight: 700;
      font-size: 20px;
      margin-top: 10px;
      margin-bottom: 10px;
    }

    .note {
      background-color: var(--orange);
      color: var(--cream);
      padding: 30px;
      border-radius: 25px;
      max-width: 700px;
      margin: 30px auto;
      font-size: 22px;
      font-weight: bold;
      border: 3px solid var(--burg);
    }

    .tag {
      display: inline-block;
      background-color: var(--blue);
      color: var(--offblack);
      padding: 8px 14px;
      border-radius: 999px;
      margin: 6px;
      font-weight: bold;
      border: 2px solid var(--offblack);
    }

    .tag.orange {
      background-color: var(--orange);
      color: var(--cream);
    }

    .tag.yellow {
      background-color: var(--yellow);
    }

    .tag.olive {
      background-color: var(--olive);
      color: var(--cream);
    }

    .tag.pink {
      background-color: var(--pink);
    }

    .mini-heading {
      font-family: 'Quicksand', sans-serif;
      color: var(--olive);
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 10px;
    }

    footer {
      text-align: center;
      padding: 35px 20px;
      background-color: var(--brown);
      color: var(--cream);
    }

    footer p {
      margin-bottom: 0;
    }

    @media (max-width: 600px) {
      h1 {
        font-size: 42px;
      }

      h2 {
        font-size: 28px;
      }

      p {
        font-size: 16px;
      }

      header {
        padding: 70px 20px 50px;
      }
    }
  </style>
    nav {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 18px;
      padding: 18px 20px;
      background-color: var(--cream);
      border-bottom: 2px solid var(--brown);
      flex-wrap: wrap;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    nav a {
      color: var(--brown);
      text-decoration: none;
      font-weight: 700;
      font-size: 15px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    nav a:hover {
      color: var(--orange);
    }

    .nav-button {
      background-color: var(--olive);
      color: var(--cream);
      padding: 8px 14px;
      border-radius: 999px;
      border: 2px solid var(--olive);
    }

    .nav-button:hover {
      background-color: var(--brown);
      border-color: var(--brown);
      color: var(--cream);
    }
</head>

